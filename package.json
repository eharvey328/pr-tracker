{
  "name": "pr-tracker",
  "version": "1.0.0",
  "description": "GitHub PR status tracker with Slack notifications",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "tsx watch src/app.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@octokit/auth-app": "^7.0.0",
