    "@slack/web-api": "^7.0.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@octokit/types": "^16.0.0",
    "@octokit/webhooks-types": "^7.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
