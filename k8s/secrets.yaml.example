# This is an example secrets file. DO NOT commit actual secrets to git.
# Create the actual secrets.yaml file with your real values and apply it manually.
#
# To create secrets from this template:
# 1. Copy this file: cp k8s/secrets.yaml.example k8s/secrets.yaml
# 2. Replace all placeholder values with your actual secrets
# 3. Apply: kubectl apply -f k8s/secrets.yaml
# 4. DO NOT commit secrets.yaml to git (it's in .gitignore)
#
# Alternatively, create secrets using kubectl commands:
#
# kubectl create secret generic pr-tracker-secrets \
#   --from-literal=github-app-id=YOUR_APP_ID \
#   --from-literal=github-webhook-secret=YOUR_WEBHOOK_SECRET \
#   --from-literal=slack-bot-token=xoxb-YOUR-TOKEN \
#   --from-literal=slack-signing-secret=YOUR_SIGNING_SECRET \
#   --from-file=github-private-key=./private-key.pem \
#   -n pr-tracker
#
# kubectl create secret docker-registry icr-secret \
#   --docker-server=us.icr.io \
#   --docker-username=iamapikey \
#   --docker-password=YOUR_IBM_CLOUD_API_KEY \
#   -n pr-tracker

---
apiVersion: v1
kind: Secret
metadata:
  name: pr-tracker-secrets
  namespace: pr-tracker
type: Opaque
stringData:
  github-app-id: "12345"  # Replace with your GitHub App ID
  github-webhook-secret: "your-webhook-secret-here"  # Replace with your webhook secret
  slack-bot-token: "xoxb-your-slack-bot-token-here"  # Replace with your Slack bot token
  slack-signing-secret: "your-slack-signing-secret-here"  # Replace with your Slack signing secret
  github-private-key: |
    -----BEGIN RSA PRIVATE KEY-----
    YOUR_PRIVATE_KEY_CONTENT_HERE
    Replace this entire block with the contents of your private-key.pem file
    -----END RSA PRIVATE KEY-----

---
apiVersion: v1
kind: Secret
metadata:
  name: icr-secret
  namespace: pr-tracker
type: kubernetes.io/dockerconfigjson
data:
  .dockerconfigjson: BASE64_ENCODED_DOCKER_CONFIG
  # To generate this value:
  # kubectl create secret docker-registry icr-secret \
  #   --docker-server=us.icr.io \
  #   --docker-username=iamapikey \
  #   --docker-password=YOUR_IBM_CLOUD_API_KEY \
  #   --dry-run=client -o yaml \
  #   -n pr-tracker
  # Then copy the .dockerconfigjson value here